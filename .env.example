# Copy to .env and adjust. `podman-compose up -d --build` reads it.

# --- mediation server ---
# listen port (also the published container port)
PORT=4100
# in-container path; ./data is bind-mounted here
DB_PATH=/data/mediation.db
# session expiry without heartbeat (default 120000)
SESSION_TTL_MS=120000

# --- Pangolin Newt tunnel (optional) ---
# Fill these from your Pangolin dashboard: Sites -> Add Site -> Newt.
# Leave empty to run mediation without the tunnel (newt just crash-loops).
PANGOLIN_ENDPOINT=
NEWT_ID=
NEWT_SECRET=
